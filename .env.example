# Copy to .env.local for local development. Do NOT commit .env.local.
# All values are placeholders — replace before launch.

# Optional analytics. Leave unset to disable. (Wire in app/layout.tsx if you add it.)
NEXT_PUBLIC_ANALYTICS_ID=

# Public site URL — used by sitemap, robots, and canonical tags.
# On GitHub Pages this should be the full Pages URL including the basePath, e.g.
#   https://meechi3t.github.io/pats-pressure-washing
NEXT_PUBLIC_SITE_URL=https://meechi3t.github.io/pats-pressure-washing
