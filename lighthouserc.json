{
  "ci": {
    "collect": {
      "url": [
        "http://localhost:3000/",
        "http://localhost:3000/service-areas/sacramento",
        "http://localhost:3000/services/house-washing",
        "http://localhost:3000/quote"
      ],
      "startServerCommand": "npm run start",
      "startServerReadyPattern": "Ready",
      "numberOfRuns": 1
    },
    "assert": {
      "preset": "lighthouse:no-pwa"
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci"
    }
  }
}
